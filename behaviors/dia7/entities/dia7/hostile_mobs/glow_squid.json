			},
			"minecraft:offspring": {
				"offspring_pairs": {
					"minecraft:glow_squid": "minecraft:glow_squid"
				}
			},
			"minecraft:physics": {},
			"minecraft:pushable": {
				"is_pushable": true,
				"is_pushable_by_piston": true
			},
			"minecraft:spawn_egg_interaction": {},
			"minecraft:type_family": {
				"family": [
					"aquatic",
					"squid",
					"mob"
				]
			}
		},
		"component_groups": {
			"ha:explode": {
				"minecraft:damage_sensor": { },
				"minecraft:explode": {
					"power": 4,
					"fuse_length": [
						0.7,
						0.7
					],
					"fuse_lit": true,
					"allow_underwater": true,
					"breaks_blocks": true,
					"causes_fire": false,
					"destroy_affected_by_griefing": true,
					"fire_affected_by_griefing": true,
					"toggles_blocks": true,
					"knockback_scaling": 3
				}
			},
			"minecraft:squid_adult": {
				"minecraft:leashable_to": {}
			},
			"minecraft:squid_baby": {
				"minecraft:is_baby": {},
				"minecraft:ageable": {
					"duration": 1200,
					"pause_growth_items": [
						"golden_dandelion"
					],
					"reset_growth_items": [
						"golden_dandelion"
					],
					"grow_up": {
						"event": "minecraft:ageable_grow_up",
						"target": "self"
					}
				},
				"minecraft:scale": {
					"value": 0.5
				}
			}
		},
		"events": {
			"ha:start_explode": {
				"queue_command": {
					"command": [
						"playsound mob.start_exploding.sound @a ~~~"
					]
				},
				"add": {
					"component_groups": [
						"ha:explode"
					]
				}
			},
			"minecraft:entity_born": {
				"add": {
					"component_groups": [
						"minecraft:squid_baby"
					]
				}
			},
			"minecraft:entity_spawned": {
				"randomize": [
					{
						"add": {
							"component_groups": [
								"minecraft:squid_adult"
							]
						},
						"weight": 95
					},
					{
						"trigger": "minecraft:entity_born",
						"weight": 5
					}
				]
			},
			"minecraft:ageable_grow_up": {
				"remove": {
					"component_groups": [
						"minecraft:squid_baby"
					]
				},
				"add": {
					"component_groups": [
						"minecraft:squid_adult"
					]
				}
			}
		}
	}
}