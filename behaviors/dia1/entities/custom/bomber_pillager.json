                "sequence": [
                    {
                        "add": { "component_groups": [ "minecraft:celebrate" ] }
                    },
                    {
                        "filters": { "test": "has_nametag", "value": false },
                        "remove": { "component_groups": [ "minecraft:raid_persistence" ] }
                    }
