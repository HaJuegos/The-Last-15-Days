            },
            "minecraft:stop_celebrating": {
                "remove": { "component_groups": [ "minecraft:celebrate" ] }
            },
            "minecraft:raid_expired": {
                "sequence": [
                    {
                        "filters": { "test": "has_nametag", "value": false },
