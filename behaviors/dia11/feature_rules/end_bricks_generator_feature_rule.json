{
    "format_version": "1.13.0",
    "minecraft:feature_rules": {
        "description": {
            "identifier": "ha:end_bricks_generator_feature_rule",
            "places_feature": "ha:end_bricks_feature"
        },
        "conditions": {
            "placement_pass": "underground_pass",
            "minecraft:biome_filter": [
                {
                    "test": "has_biome_tag",
                    "operator": "==",
                    "value": "the_end"
                }
            ]
        },
        "distribution": {
            "iterations": "(math.abs(v.originx) <= 300 && math.abs(v.originz) <= 300) * 35",
            "coordinate_eval_order": "zyx",
            "x": {
                "distribution": "uniform",
                "extent": [ 0, 15 ]
            },
            "y": {
                "distribution": "uniform",
                "extent": [ 10, 70 ]
            },
            "z": {
                "distribution": "uniform",
                "extent": [ 0, 15 ]
            }
        }
    }
}