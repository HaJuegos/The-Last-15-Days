                    "default": "normal"
                }
            }
        },
        "component_groups": {
            "ha:witch_potion": {
                "minecraft:projectile": {
                    "angle_offset": -20.0,
                    "on_hit": {
                        "definition_event": {
                            "affect_projectile": true,
                            "event_trigger": {
                                "event": "ha:witch_events_potion",
                                "target": "self"
                            }
                        },
                        "douse_fire": { },
                        "impact_damage": null,
                        "thrown_potion_effect": { }
                    },
                    "gravity": 0.05,
                    "hit_sound": "glass",
                    "power": 0.5
                }
            }
        },
        "components": {
            "minecraft:collision_box": {
                "height": 0.25,
                "width": 0.25
            },
            "minecraft:conditional_bandwidth_optimization": {
                "default_values": {
                    "max_dropped_ticks": 5,
                    "max_optimized_distance": 80.0,
                    "use_motion_prediction_hints": true
                }
            },
            "minecraft:physics": { },
