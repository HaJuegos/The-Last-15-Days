                "hit_sound": "glass",
                "power": 0.5
            },
            "minecraft:pushable": {
                "is_pushable": true,
                "is_pushable_by_piston": true
            }
        },
        "events": {
            "minecraft:entity_spawned": { },
            "ha:witch_events_potion": {
                "queue_command": {
                    "command": [
                        "scriptevent ha:witch_potion_x"
                    ]
                }
            },
            "ha:witch_damage_potion": {
                "set_property": {
                    "ha:type_potion": "damage"
                },
                "add": {
