{
    "format_version": "1.26.0",
    "minecraft:entity": {
        "description": {
            "identifier": "minecraft:splash_potion",
            "is_experimental": false,
            "is_summonable": true,
            "is_spawnable": false,
            "spawn_category": "misc",
            "properties": {
                "ha:type_potion": {
                    "type": "enum",
                    "values": [
                        "normal",
                        "damage",
                        "health",
                        "regeneration",
                        "slowness",
                        "poison",
                        "weakness"
