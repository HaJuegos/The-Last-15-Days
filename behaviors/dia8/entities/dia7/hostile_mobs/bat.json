{
	"format_version": "1.26.0",
	"minecraft:entity": {
		"description": {
			"identifier": "minecraft:bat",
			"is_experimental": false,
			"is_summonable": true,
			"is_spawnable": true,
			"spawn_category": "ambient"
		},
		"component_groups": {
			"ha:explode": {
				"minecraft:damage_sensor": { },
				"minecraft:explode": {
					"power": 4,
					"fuse_length": [
						0.7,
						0.7
					],
					"fuse_lit": true,
					"allow_underwater": true,
					"breaks_blocks": true,
					"causes_fire": false,
					"destroy_affected_by_griefing": true,
					"fire_affected_by_griefing": true,
					"toggles_blocks": true,
					"knockback_scaling": 3
				}
			}
		},
		"components": {
			"minecraft:attack": {
				"damage": 6
			},
			"minecraft:behavior.melee_box_attack": {
				"priority": 0,
				"can_spread_on_fire": true,
				"horizontal_reach": 1.15,
				"melee_fov": 360,
				"track_target": true,
				"speed_multiplier": 1.35,
				"on_attack": {
					"filters": {
						"test": "has_component",
						"subject": "self",
						"operator": "!=",
						"value": "minecraft:explode"
					},
					"target": "self",
					"event": "ha:start_explode"
				}
			},
			"minecraft:behavior.hurt_by_target": {
				"priority": 1
			},
			"minecraft:behavior.nearest_attackable_target": {
				"priority": 2,
				"must_see": true,
				"reselect_targets": true,
				"entity_types": [
					{
						"filters": {
							"any_of": [
								{
									"test": "is_family",
									"subject": "other",
									"value": "player"
								},
								{
									"test": "is_family",
									"subject": "other",
									"value": "irongolem"
								},
								{
									"test": "is_family",
									"subject": "other",
									"value": "snowgolem"
								}
							]
						},
						"max_dist": 30
					}
				]
			},
			"minecraft:behavior.random_hover": {
				"hover_height": [
					1,
					4
				],
				"y_dist": 8,
				"interval": 1,
				"xz_dist": 8,
				"priority": 9,
				"y_offset": -1
			},
			"minecraft:behavior.random_look_around": {
				"priority": 8
			},
			"minecraft:behavior.float": {
				"priority": 4
			},
			"minecraft:can_fly": { },
			"minecraft:jump.static": { },
			"minecraft:flying_speed": {
				"value": 0.25
			},
			"minecraft:follow_range": {
				"value": 1024
			},
			"minecraft:movement": {
				"value": 0.25
			},
			"minecraft:movement.hover": { },
			"minecraft:navigation.hover": {
				"can_path_from_air": true,
				"can_path_over_water": true,
				"can_sink": false,
				"avoid_water": true,
				"avoid_damage_blocks": true
			},
			"minecraft:damage_sensor": {
				"triggers": [
					{
						"on_damage": {
							"filters": {
								"test": "has_component",
								"subject": "self",
								"operator": "!=",
								"value": "minecraft:explode"
							},
							"target": "self",
							"event": "ha:start_explode"
						},
						"cause": "all",
						"deals_damage": "yes"
					},
					{
						"cause": "fall",
						"deals_damage": "no"
					}
				]
			},
			"minecraft:breathable": {
				"suffocate_time": 0,
				"total_supply": 15
			},
			"minecraft:collision_box": {
				"height": 0.9,
				"width": 0.5
			},
			"minecraft:conditional_bandwidth_optimization": { },
			"minecraft:despawn": {
				"despawn_from_distance": { }
			},
			"minecraft:game_event_movement_tracking": {
				"emit_flap": true
			},
			"minecraft:health": {
				"max": 6,
				"value": 6
			},
			"minecraft:hurt_on_condition": {
				"damage_conditions": [
					{
						"cause": "lava",
						"damage_per_tick": 4,
						"filters": {
							"operator": "==",
							"test": "in_lava",
							"subject": "self",
							"value": true
						}
					}
				]
			},
			"minecraft:is_hidden_when_invisible": { },
			"minecraft:nameable": { },
			"minecraft:physics": {
				"has_gravity": false
			},
			"minecraft:pushable": {
				"is_pushable": true,
				"is_pushable_by_piston": true
			},
			"minecraft:type_family": {
				"family": [
					"bat",
					"mob"
				]
			}
		},
		"events": {
			"ha:start_explode": {
				"queue_command": {
					"command": [
						"playsound mob.start_exploding.sound @a ~~~"
					]
				},
				"add": {
					"component_groups": [
						"ha:explode"
					]
				}
			}
		}
	}
}