{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ES2020",
        "moduleResolution": "node",
        "lib": [
            "ES2020",
            "dom"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "allowJs": true,
        "checkJs": true,
        "noImplicitAny": true,
        "noResolve": false,
        "traceResolution": false,
        "sourceMap": false
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}