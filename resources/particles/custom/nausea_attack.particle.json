	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "ha:nausea_attack",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/particle/nausea_attack_particle"
			}
