                    "texture_height": 12,
                    "uv": [
                        0,
                        "Math.floor(variable.particle_random_2 * 12)"
                    ],
                    "uv_size": [
                        1,
                        1
                    ]
                }
            },
            "minecraft:particle_motion_collision": {
                "enabled": "variable.particle_age > 1",
                "collision_radius": 0.25,
                "collision_drag": 0.8,
                "coefficient_of_restitution": 0.3
