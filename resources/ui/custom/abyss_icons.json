{
    "namespace": "abyss_icons",

    // Animations Section

    "base_pop": {
        "anim_type": "size",
        "from": [ 0, 0 ],
        "to": [ 148, 148 ],
        "duration": 0.15,
        "easing": "out_back",
        "next": "@abyss_icons.base_wait"
    },
    "base_wait": {
        "anim_type": "wait",
        "duration": 0.1,
        "next": "@abyss_icons.base_hide"
    },
    "base_hide": {
        "anim_type": "alpha",
        "from": 1.0,
        "to": 0.0,
        "duration": 0.05
    },

    "number_delay": {
        "anim_type": "size",
        "from": [ 0, 0 ],
        "to": [ 0, 0 ],
        "duration": 0.25,
        "next": "@abyss_icons.number_pop"
    },
    "number_pop": {
        "anim_type": "size",
        "from": [ 148, 148 ],
        "to": [ 200, 200 ],
        "duration": 0.35,
        "easing": "out_bounce",
        "next": "@abyss_icons.number_pop_static"
    },
    "number_pop_static": {
        "anim_type": "size",
        "from": [ 200, 200 ],
        "to": [ 148, 148 ],
        "duration": 0.15,
        "easing": "out_bounce",
        "next": "@abyss_icons.number_wait"
    },
    "number_wait": {
        "anim_type": "wait",
        "duration": 1.0,
        "next": "@abyss_icons.fade_out"
    },
    "fade_out": {
        "anim_type": "alpha",
        "from": 1.0,
        "to": 0.0,
        "duration": 0.5
    },

    // Icons template base

    "debuff_combo_template": {
        "type": "image",
        "size": [ 148, 148 ],
        "layer": 101,
        "anims": [
            "@abyss_icons.number_delay"
        ]
    },
    "debuff_base_combo_template": {
        "type": "image",
        "size": [ 148, 148 ],
        "layer": 100,
        "anims": [
            "@abyss_icons.base_pop"
        ]
    },

