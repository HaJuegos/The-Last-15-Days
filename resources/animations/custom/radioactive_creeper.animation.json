{
    "format_version": "1.10.0",
    "animations": {
        "animation.radioactive_creeper.idle": {
            "loop": true,
            "bones": {
                "head": {
                    "rotation": [ 0, 0, "-10 * math.sin(query.life_time * 120)" ]
                },
                "bone": {
                    "rotation": [ 0, 0, "10 * math.sin(query.life_time * 120)" ],
                    "position": [ "-0.45 * math.sin(query.life_time * 120)", "-0.5 * math.sin(query.life_time * 120)", 0 ],
                    "scale": [ 1, "1 + math.sin(query.life_time * 120) * 1", 1 ]
                }
            }
        }
    }
}