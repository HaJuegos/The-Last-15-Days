/* Created or modified by Ha Juegos. Free to use file, any modification or editing of it must be credited. Thank you, any information at: https://github.com/HaJuegos/The-Last-15-Days. */
{
    "format_version": "1.10.0",
    "render_controllers": {
        "controller.render.sheep.v2": {
            "arrays": {
                "geometries": {
                    "Array.geos": [
                        "Geometry.default",
                        "Geometry.sheared"
                    ]
                }
            },
            "geometry": "query.skin_id == 1 ? Geometry.iron : (query.is_baby ? Geometry.baby : Array.geos[query.is_sheared])",
            "materials": [
                {
                    "*": "query.skin_id == 1 ? Material.iron : Material.default"
                }
            ],
            "textures": [
                "query.skin_id == 1 ? Texture.iron : (query.is_baby ? Texture.baby : Texture.default)"
            ]
        }
    }
}