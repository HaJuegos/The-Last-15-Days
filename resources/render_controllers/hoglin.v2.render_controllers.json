/* Created or modified by Ha Juegos. Free to use file, any modification or editing of it must be credited. Thank you, any information at: https://github.com/HaJuegos/The-Last-15-Days. */
{
    "format_version": "1.10.0",
    "render_controllers": {
        "controller.render.hoglin.v2": {
            "arrays": {
                "geometries": {
                    "Array.geos": [
                        "Geometry.default",
                        "Geometry.new"
                    ]
                },
                "textures": {
                    "Array.skins": [
                        "Texture.default",
                        "Texture.new"
                    ]
                }
            },
            "geometry": "query.is_baby ? Geometry.baby : Array.geos[query.skin_id == 1 ? 1 : 0]",
            "materials": [
                {
                    "*": "Material.default"
                }
            ],
            "textures": [
                "query.is_baby ? Texture.baby : Array.skins[query.skin_id == 1 ? 1 : 0]"
            ]
        }
    }
}
