{
    "format_version": "1.10.0",
    "render_controllers": {
        "controller.render.bomber_pillager": {
            "geometry": "Geometry.default",
            "materials": [
                {
                    "*": "Material.default"
                }
            ],
            "textures": [
                "Texture.default"
            ],
            "overlay_color": {
                "a": "q.is_pregnant * (Math.sin(query.life_time * (400 + (query.life_time * 150))) > 0 ? 0.8 : 0.0)",
                "r": "q.is_pregnant * Math.lerp(1.0, 1.0, query.life_time)",
                "g": "q.is_pregnant * Math.clamp(1.0 - (query.life_time * 2.0), 0.0, 1.0)",
                "b": "q.is_pregnant * Math.clamp(1.0 - (query.life_time * 2.0), 0.0, 1.0)"
            }
        }
    }
}