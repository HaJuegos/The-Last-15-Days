{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.soul_ghast.root": {
            "initial_state": "default",
            "states": {
               "default": {
                    "transitions": [
                        { "on_chargin": "q.facing_target_to_range_attack" }
                    ]
                },
                "on_chargin": {
                    "animations": [ "chargin" ],
                    "transitions": [
                        { "on_shoot": "q.is_charged && q.anim_time >= 2.8" },
                        { "default": "!q.facing_target_to_range_attack" }
                    ]
                },
                "on_shoot": {
                    "animations": [ "shoot" ],
                    "transitions": [
                        { "on_chargin": "q.all_animations_finished" },
                        { "default": "!q.facing_target_to_range_attack" }
                    ]
                }
            }
        }
    }
}